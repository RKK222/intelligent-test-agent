# 本地开发环境变量配置
# 复制此文件为 .env.local 并根据本地环境修改

# Java 版本，默认 21，可设为 25 等
# 脚本会自动查找对应的 JAVA_HOME
JAVA_VERSION=21
# 或者直接指定 JAVA_HOME（优先级更高）
# JAVA_HOME=/path/to/your/java/home

SPRING_PROFILES_ACTIVE=local

# 与 tools/dev-local-up.sh / deploy/local/docker-compose.yml 的默认 PostgreSQL 一致。
TEST_AGENT_DB_URL=jdbc:postgresql://127.0.0.1:15432/test_agent
TEST_AGENT_DB_USERNAME=test_agent
TEST_AGENT_DB_PASSWORD=test_agent

# XXL-JOB 使用完全独立的 MySQL 8.4；镜像只建库和账号，V1～V3 表结构及首批任务由应用 Flyway 初始化。
TEST_AGENT_XXL_JOB_ENABLED=true
TEST_AGENT_XXL_JOB_MYSQL_URL=jdbc:mysql://127.0.0.1:13306/xxl_job?useUnicode=true&characterEncoding=UTF-8&serverTimezone=Asia/Shanghai
TEST_AGENT_XXL_JOB_MYSQL_USERNAME=xxl_job
TEST_AGENT_XXL_JOB_MYSQL_PASSWORD=xxl_job
TEST_AGENT_XXL_JOB_ACCESS_TOKEN=<replace-with-local-shared-access-token>
TEST_AGENT_XXL_JOB_ADMIN_PORT=18080
TEST_AGENT_XXL_JOB_EXECUTOR_PORT=9999
# Vite 将同源 /xxl-job-admin/ 转发到该地址。
TEST_AGENT_XXL_JOB_ADMIN_URL=http://127.0.0.1:18080

TEST_AGENT_REDIS_HOST=<your-redis-host>
TEST_AGENT_REDIS_PORT=6379
TEST_AGENT_REDIS_PASSWORD=<your-redis-password>

# 夜间异步执行依赖 scheduler；容量表示每个 15 分钟启动时段的全局任务数上限。
TEST_AGENT_SCHEDULER_ENABLED=true
TEST_AGENT_SCHEDULER_USER_PLAN_RUN_LIMIT=50
TEST_AGENT_SCHEDULER_USER_PLAN_WORKER_COUNT=4
TEST_AGENT_SCHEDULER_USER_PLAN_QUEUE_CAPACITY=100

TEST_AGENT_OPENCODE_BASE_URL=http://127.0.0.1:4096
# 本地一键启动脚本用该地址判断是否启动 opencode-manager，并据此派生本地端口池；
# Java 后端不再从 yml 读取该值 seed 固定 opencode 节点。
# 指定二进制可避免系统 PATH 命中旧版本。
# TEST_AGENT_OPENCODE_BIN=${HOME}/.opencode/bin/opencode
# TEST_AGENT_START_OPENCODE=auto
# 本地种子 F-COSS 工作区目录缺失时，启动脚本会从 test-workspaces/F-COSS 初始化到 /tmp/test-agent/fcoss/*。
# TEST_AGENT_SEED_DEMO_WORKSPACES=auto

# 模型目录来源：本地外网测试默认 external；企业内联调改为 internal
TEST_AGENT_MODEL_CATALOG_SOURCE=external

# 外部 OpenAI-compatible 模型服务，例如 DeepSeek
TEST_AGENT_EXTERNAL_MODEL_PROVIDER_ID=deepseek
TEST_AGENT_EXTERNAL_MODEL_PROVIDER_NAME=DeepSeek
TEST_AGENT_EXTERNAL_MODEL_BASE_URL=https://api.deepseek.com
TEST_AGENT_EXTERNAL_MODEL_API_KEY_ENV=EXTERNAL_API_KEY
EXTERNAL_API_KEY=<your-external-api-key>
TEST_AGENT_EXTERNAL_MODEL_DEFAULT_MODEL=deepseek-v4-pro

# 企业内 enterprise-openai；TEST_AGENT_MODEL_CATALOG_SOURCE=internal 时启用
# ENTERPRISE_OPENAI_AUTH_TOKEN=<your-enterprise-openai-token>
# TEST_AGENT_ENTERPRISE_OPENAI_BASE_URL=http://ai-code.sdc.icbc:9070/enterprise/jdt/model/api/openai/v1
# TEST_AGENT_INTERNAL_DEFAULT_MODEL=DeepSeek-V4-Flash-W8A8
