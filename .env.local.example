# 环境变量模板文件
# 复制此文件为 .env.local 并根据本地环境修改

# ============================================================================
# Spring Profile 配置
# ============================================================================
# 指定 Spring 激活的 profile，支持: local, test, prod 等
# 默认值: local (application.yml 中配置)
# SPRING_PROFILES_ACTIVE=local

# ============================================================================
# 数据库配置 (本地开发)
# ============================================================================
TEST_AGENT_LOCAL_DB_HOST=127.0.0.1
TEST_AGENT_LOCAL_DB_PORT=15432
TEST_AGENT_LOCAL_DB_NAME=test_agent
TEST_AGENT_LOCAL_DB_USERNAME=test_agent
TEST_AGENT_LOCAL_DB_PASSWORD=test_agent

# ============================================================================
# Redis 配置
# ============================================================================
TEST_AGENT_REDIS_ENABLED=false
TEST_AGENT_REDIS_HOST=127.0.0.1
TEST_AGENT_REDIS_PORT=6379
TEST_AGENT_REDIS_PASSWORD=
TEST_AGENT_REDIS_TIMEOUT=1s

# ============================================================================
# OpenCode 配置
# ============================================================================
TEST_AGENT_OPENCODE_BASE_URL=http://127.0.0.1:4096

# ============================================================================
# Spring 应用配置 (JSON 格式)
# ============================================================================
# 用于覆盖 Spring 配置，如健康检查、opencode nodes 等
SPRING_APPLICATION_JSON={"management":{"health":{"opencodeNodes":{"enabled":false},"redisOptional":{"enabled":false}}},"test-agent":{"opencode":{"nodes":[]}}}

# ============================================================================
# 其他配置
# ============================================================================
# TEST_AGENT_API_TOKEN=
# TEST_AGENT_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# TEST_AGENT_RATE_LIMIT_ENABLED=false
# TEST_AGENT_MAX_FILE_BYTES=1048576
# TEST_AGENT_MANAGED_WORKSPACE_ROOT=
