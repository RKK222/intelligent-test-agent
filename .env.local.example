# 本地开发环境变量配置
# 复制此文件为 .env.local 并根据本地环境修改

# Java 版本，默认 21，可设为 25 等
# 脚本会自动查找对应的 JAVA_HOME
JAVA_VERSION=21
# 或者直接指定 JAVA_HOME（优先级更高）
# JAVA_HOME=/path/to/your/java/home

SPRING_PROFILES_ACTIVE=local

TEST_AGENT_LOCAL_DB_HOST=<your-db-host>
TEST_AGENT_LOCAL_DB_PORT=5432
TEST_AGENT_LOCAL_DB_NAME=testagent
TEST_AGENT_LOCAL_DB_USERNAME=<your-db-username>
TEST_AGENT_LOCAL_DB_PASSWORD=<your-db-password>

TEST_AGENT_REDIS_HOST=<your-redis-host>
TEST_AGENT_REDIS_PORT=6379
TEST_AGENT_REDIS_PASSWORD=<your-redis-password>

TEST_AGENT_OPENCODE_BASE_URL=http://127.0.0.1:4096