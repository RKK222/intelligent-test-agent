<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.enterprise.testagent.persistence.mybatis.CommonParameterChangeLogMapper">
    <resultMap id="CommonParameterChangeLogRowMap" type="com.enterprise.testagent.persistence.mybatis.CommonParameterChangeLogRow">
        <constructor>
            <arg column="log_id" javaType="java.lang.String"/>
            <arg column="parameter_id" javaType="java.lang.String"/>
            <arg column="old_value" javaType="java.lang.String"/>
            <arg column="new_value" javaType="java.lang.String"/>
            <arg column="changed_by_user_id" javaType="java.lang.String"/>
            <arg column="changed_by_username" javaType="java.lang.String"/>
            <arg column="trace_id" javaType="java.lang.String"/>
            <arg column="created_at" javaType="java.time.Instant"/>
        </constructor>
    </resultMap>

    <sql id="CommonParameterChangeLogColumns">
        log_id, parameter_id, old_value, new_value, changed_by_user_id, changed_by_username, trace_id, created_at
    </sql>

    <insert id="insert">
        insert into common_parameter_change_logs (
            log_id, parameter_id, old_value, new_value, changed_by_user_id, changed_by_username, trace_id, created_at
        ) values (
            #{logId}, #{parameterId}, #{oldValue}, #{newValue}, #{changedByUserId}, #{changedByUsername}, #{traceId}, #{createdAt}
        )
    </insert>

    <select id="findByParameterId" resultMap="CommonParameterChangeLogRowMap">
        select
        <include refid="CommonParameterChangeLogColumns"/>
        from common_parameter_change_logs
        where parameter_id = #{parameterId}
        order by created_at desc
        limit #{limit}
    </select>
</mapper>