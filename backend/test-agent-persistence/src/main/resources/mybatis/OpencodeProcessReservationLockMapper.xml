<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.enterprise.testagent.persistence.mybatis.OpencodeProcessReservationLockMapper">
    <select id="lockUser" resultType="java.lang.String">
        select user_id
        from users
        where user_id = #{userId}
        for update
    </select>

    <select id="lockLinuxServer" resultType="java.lang.String">
        select linux_server_id
        from linux_servers
        where linux_server_id = #{linuxServerId}
        for update
    </select>
</mapper>
