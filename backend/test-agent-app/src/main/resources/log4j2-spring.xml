<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN" monitorInterval="30">
    <Properties>
        <Property name="structuredPattern">timestamp=&quot;%d{yyyy-MM-dd'T'HH:mm:ss.SSSXXX}&quot; level=%p traceId=&quot;%enc{%X{traceId}}{CRLF}&quot; module=backend logger=&quot;%c{1.}&quot; thread=&quot;%enc{%t}{CRLF}&quot; message=&quot;%enc{%m}{CRLF}&quot;%n%xEx</Property>
    </Properties>
    <Appenders>
        <Console name="Console" target="SYSTEM_OUT">
            <PatternLayout pattern="${structuredPattern}"/>
        </Console>
        <!-- 按周滚动文件，历史日志压缩为 .gz；当前周写入 backend.log，每周一切换并归档 -->
        <RollingFile name="BackendFile"
                     fileName="logs/backend.log"
                     filePattern="logs/backend-%d{yyyy-MM-dd}.log.gz">
            <PatternLayout pattern="${structuredPattern}"/>
            <Policies>
                <!-- 按周滚动：interval=7 表示每 7 天滚动一次 -->
                <TimeBasedTriggeringPolicy interval="7" modulate="true"/>
            </Policies>
            <DefaultRolloverStrategy max="12"/>
        </RollingFile>
        <!-- SSE 相关 logger 额外写入独立文件，同时继续通过 root 进入 backend.log。 -->
        <RollingFile name="SseFile"
                     fileName="logs/sse.log"
                     filePattern="logs/sse-%d{yyyy-MM-dd}.log.gz">
            <PatternLayout pattern="${structuredPattern}"/>
            <Policies>
                <TimeBasedTriggeringPolicy interval="7" modulate="true"/>
            </Policies>
            <DefaultRolloverStrategy max="12"/>
        </RollingFile>
        <!-- error.log 仅接收 ERROR 及以上级别，便于快速排查失败。 -->
        <RollingFile name="ErrorFile"
                     fileName="logs/error.log"
                     filePattern="logs/error-%d{yyyy-MM-dd}.log.gz">
            <ThresholdFilter level="ERROR" onMatch="ACCEPT" onMismatch="DENY"/>
            <PatternLayout pattern="${structuredPattern}"/>
            <Policies>
                <TimeBasedTriggeringPolicy interval="7" modulate="true"/>
            </Policies>
            <DefaultRolloverStrategy max="12"/>
        </RollingFile>
    </Appenders>

    <Loggers>
        <Logger name="com.enterprise.testagent" level="INFO"/>
        <Logger name="com.enterprise.testagent.event" level="INFO">
            <AppenderRef ref="SseFile"/>
        </Logger>
        <Logger name="com.enterprise.testagent.api.web.platform.BackendSseForwarder" level="INFO">
            <AppenderRef ref="SseFile"/>
        </Logger>
        <Logger name="com.enterprise.testagent.api.web.platform.RunEventSseBackendRoutingWebFilter" level="INFO">
            <AppenderRef ref="SseFile"/>
        </Logger>
        <Logger name="com.enterprise.testagent.api.web.platform.SessionRuntimeStateController" level="INFO">
            <AppenderRef ref="SseFile"/>
        </Logger>
        <Logger name="com.enterprise.testagent.opencode.runtime.session.SessionRuntimeStateApplicationService" level="INFO">
            <AppenderRef ref="SseFile"/>
        </Logger>
        <Root level="INFO">
            <AppenderRef ref="Console"/>
            <AppenderRef ref="BackendFile"/>
            <AppenderRef ref="ErrorFile"/>
        </Root>
    </Loggers>
</Configuration>
