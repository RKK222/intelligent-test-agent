<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <parent>
        <groupId>org.springframework.boot</groupId>
        <artifactId>spring-boot-starter-parent</artifactId>
        <version>4.1.0</version>
        <relativePath/>
    </parent>

    <groupId>com.example.testagent</groupId>
    <artifactId>test-agent-backend</artifactId>
    <version>0.1.0-SNAPSHOT</version>
    <packaging>pom</packaging>
    <name>test-agent-backend</name>
    <description>Single-service backend for the opencode-based intelligent test agent platform.</description>

    <modules>
        <module>test-agent-common</module>
        <module>test-agent-domain</module>
        <module>test-agent-observability</module>
        <module>test-agent-opencode-sdk-generated</module>
        <module>test-agent-opencode-client</module>
        <module>test-agent-persistence</module>
        <module>test-agent-event</module>
        <module>test-agent-test-support</module>
        <module>test-agent-app</module>
    </modules>

    <properties>
        <java.version>21</java.version>
        <maven.compiler.release>21</maven.compiler.release>
        <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
        <project.reporting.outputEncoding>UTF-8</project.reporting.outputEncoding>
        <druid.version>1.2.28</druid.version>
        <start-class>com.example.testagent.app.TestAgentApplication</start-class>
    </properties>

    <dependencyManagement>
        <dependencies>
            <dependency>
                <groupId>com.example.testagent</groupId>
                <artifactId>test-agent-common</artifactId>
                <version>${project.version}</version>
            </dependency>
            <dependency>
                <groupId>com.example.testagent</groupId>
                <artifactId>test-agent-domain</artifactId>
                <version>${project.version}</version>
            </dependency>
            <dependency>
                <groupId>com.example.testagent</groupId>
                <artifactId>test-agent-observability</artifactId>
                <version>${project.version}</version>
            </dependency>
            <dependency>
                <groupId>com.example.testagent</groupId>
                <artifactId>test-agent-opencode-sdk-generated</artifactId>
                <version>${project.version}</version>
            </dependency>
            <dependency>
                <groupId>com.example.testagent</groupId>
                <artifactId>test-agent-opencode-client</artifactId>
                <version>${project.version}</version>
            </dependency>
            <dependency>
                <groupId>com.example.testagent</groupId>
                <artifactId>test-agent-persistence</artifactId>
                <version>${project.version}</version>
            </dependency>
            <dependency>
                <groupId>com.example.testagent</groupId>
                <artifactId>test-agent-event</artifactId>
                <version>${project.version}</version>
            </dependency>
            <dependency>
                <groupId>com.example.testagent</groupId>
                <artifactId>test-agent-test-support</artifactId>
                <version>${project.version}</version>
            </dependency>
            <dependency>
                <groupId>com.alibaba</groupId>
                <artifactId>druid-spring-boot-4-starter</artifactId>
                <version>${druid.version}</version>
            </dependency>
        </dependencies>
    </dependencyManagement>
</project>
