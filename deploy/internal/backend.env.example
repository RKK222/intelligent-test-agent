# Copy this file to /data/testagent/config/backend.env on the backend server.
# Keep real secrets only on the target server or in a private transfer package.

# Java backend listens on 122.233.30.4:8080 and is accessed by the frontend Nginx on 122.233.30.2.
SPRING_PROFILES_ACTIVE=prod
SERVER_PORT=8080
TEST_AGENT_DEPLOYMENT_MODE=internal
TEST_AGENT_SERVER_ADVERTISED_HOST=122.233.30.4
TEST_AGENT_LINUX_SERVER_ID=test-agent-backend-122-233-30-4

# PostgreSQL is pending. Fill these before starting Java.
TEST_AGENT_DB_URL=jdbc:postgresql://replace-with-pg-host:5432/replace-with-database
TEST_AGENT_DB_USERNAME=replace-with-pg-username
TEST_AGENT_DB_PASSWORD=replace-with-pg-password

# Redis server.
TEST_AGENT_REDIS_HOST=122.233.30.20
TEST_AGENT_REDIS_PORT=6379
TEST_AGENT_REDIS_PASSWORD=

# Browser entry is the frontend Nginx server. Keep this in sync with deploy/internal/.env.
TEST_AGENT_CORS_ALLOWED_ORIGINS=http://122.233.30.2
TEST_AGENT_API_TOKEN=replace-with-platform-api-token

# Must match deploy/internal/.env on the Docker worker host.
TEST_AGENT_OPENCODE_MANAGER_TOKEN=replace-with-manager-token

# Shared data root mounted by opencode-worker.
SYS_DATA_ROOT_DIR=/data/testagent/data

# Cross-instance/event runtime. Keep enabled for enterprise deployment.
TEST_AGENT_RUN_EVENT_REDIS_BUS_ENABLED=true
TEST_AGENT_RUN_EVENT_REDIS_BUS_CHANNEL=test-agent:run-events
TEST_AGENT_SERVER_BROADCAST_ENABLED=true
TEST_AGENT_SERVER_BROADCAST_CHANNEL=test-agent:server-broadcast

# Enterprise model provider.
TEST_AGENT_MODEL_CATALOG_SOURCE=internal
TEST_AGENT_INTERNAL_DEFAULT_MODEL=Qwen3.6-35B-A3B
TEST_AGENT_ICBC_OPENAI_BASE_URL=http://ai-code.sdc.icbc:9070/icbc/jdt/model/api/openai/v1
TEST_AGENT_ICBC_OPENAI_TOKEN_ENV=ICBC_OPENAI_AUTH_TOKEN
ICBC_OPENAI_AUTH_TOKEN=replace-with-icbc-openai-token
TEST_AGENT_ICBC_OPENAI_AUTH_MODE=bearer
TEST_AGENT_ICBC_OPENAI_UCID_HEADER_NAME=ucid

# Runtime capacity and scheduler defaults.
TEST_AGENT_DB_POOL_INITIAL_SIZE=1
TEST_AGENT_DB_POOL_MIN_IDLE=1
TEST_AGENT_DB_POOL_MAX_ACTIVE=10
TEST_AGENT_DB_POOL_MAX_WAIT_MILLIS=30000
TEST_AGENT_SCHEDULER_ENABLED=false
