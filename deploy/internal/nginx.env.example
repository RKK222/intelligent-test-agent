# Copy to /data/testagent/config/nginx.env on the frontend Nginx server.
# The current enterprise Nginx is installed under /data/apps/nginx rather than the system path.

# single requires exactly one backend; multi requires at least two comma-separated backends.
TEST_AGENT_NGINX_MODE=single
TEST_AGENT_NGINX_BACKENDS=122.233.30.114:8080

TEST_AGENT_NGINX_LISTEN_PORT=80
TEST_AGENT_FRONTEND_ROOT=/data/testagent/frontend

# Must point to a .conf file included by the active Nginx main configuration.
# configure-single-deployment.sh frontend detects the actual included directory and rewrites this value.
TEST_AGENT_NGINX_CONF_PATH=/data/apps/nginx/conf/conf.d/test-agent-gateway.conf
TEST_AGENT_NGINX_BIN=/data/apps/nginx/sbin/nginx
TEST_AGENT_NGINX_PREFIX=/data/apps/nginx
TEST_AGENT_NGINX_MAIN_CONF=/data/apps/nginx/conf/nginx.conf
TEST_AGENT_NGINX_RELOAD_MODE=binary
