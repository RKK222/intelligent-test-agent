# Copy this file to /data/testagent/config/mysql.env on the PostgreSQL server.
# Production packages replace every REPLACE_ value with package-specific random secrets.

TEST_AGENT_XXL_JOB_MYSQL_IMAGE=mysql:8.4
TEST_AGENT_XXL_JOB_MYSQL_CONTAINER=test-agent-xxl-job-mysql
TEST_AGENT_XXL_JOB_MYSQL_HOST_PORT=3306
TEST_AGENT_XXL_JOB_MYSQL_DATA_ROOT=/data/testagent/mysql
TEST_AGENT_XXL_JOB_MYSQL_ROOT_PASSWORD=REPLACE_XXL_JOB_MYSQL_ROOT_PASSWORD
TEST_AGENT_XXL_JOB_MYSQL_DATABASE=xxl_job
TEST_AGENT_XXL_JOB_MYSQL_USERNAME=xxl_job
TEST_AGENT_XXL_JOB_MYSQL_PASSWORD=REPLACE_XXL_JOB_MYSQL_PASSWORD
