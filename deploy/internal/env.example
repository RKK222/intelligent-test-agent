# Copy this file to a private env file before running docker compose.

TEST_AGENT_GATEWAY_HTTP_PORT=80

# Java backends are deployed directly on the host or on reachable intranet hosts.
# The gateway container proxies /api to these two endpoints.
TEST_AGENT_BACKEND_1=host.docker.internal:8080
TEST_AGENT_BACKEND_2=host.docker.internal:8081

# Must match TEST_AGENT_OPENCODE_MANAGER_TOKEN used by both Java backend processes.
TEST_AGENT_OPENCODE_MANAGER_TOKEN=change-me-manager-token

# Java writes SYS_DATA_ROOT_DIR/.serverid and .serverhost under this host path.
TEST_AGENT_DATA_ROOT=/data/.testagent

# Frontend image build. Leave VITE_TEST_AGENT_API_BASE_URL empty for same-origin /api through gateway.
TEST_AGENT_FRONTEND_IMAGE=test-agent-frontend:internal
VITE_TEST_AGENT_API_BASE_URL=

# opencode worker image build.
TEST_AGENT_OPENCODE_WORKER_IMAGE=test-agent-opencode-worker:internal
OPENCODE_AI_PACKAGE=opencode-ai@1.17.8

# Worker port ranges must be the host-published ports Java will use in opencode baseUrl.
OPENCODE_WORKER_1_BACKEND_PORT=8080
OPENCODE_WORKER_1_PORT_START=4096
OPENCODE_WORKER_1_PORT_END=4105
OPENCODE_WORKER_2_BACKEND_PORT=8081
OPENCODE_WORKER_2_PORT_START=4106
OPENCODE_WORKER_2_PORT_END=4115

# Build mirrors.
NPM_REGISTRY=https://registry.npmmirror.com
COREPACK_NPM_REGISTRY=https://registry.npmmirror.com
GOPROXY=https://goproxy.cn,direct
DEBIAN_MIRROR=https://mirrors.tuna.tsinghua.edu.cn/debian
DEBIAN_SECURITY_MIRROR=https://mirrors.tuna.tsinghua.edu.cn/debian-security

# Image tarballs are written here by deploy/internal/build-images.sh.
TEST_AGENT_IMAGE_OUTPUT_DIR=deploy/internal/dist
