# Copy this file to /data/testagent/config/docker.env before running the pure Docker worker script.

# Enterprise deployment base directory. Keep concrete child paths below instead of relying on dotenv expansion.
TEST_AGENT_BASE_DIR=/data/testagent

# Entity Nginx reference variables. They are not consumed by the worker container.
TEST_AGENT_NGINX_LISTEN_PORT=80
TEST_AGENT_FRONTEND_ROOT=/data/testagent/frontend
TEST_AGENT_BACKEND=122.233.30.4:8080

# Must match TEST_AGENT_OPENCODE_MANAGER_TOKEN used by the Java backend process.
TEST_AGENT_OPENCODE_MANAGER_TOKEN=test-agent-manager-token-122-233-30-4

# Java writes SYS_DATA_ROOT_DIR/.serverid and .serverhost under this host path.
TEST_AGENT_DATA_ROOT=/data/testagent/data

# External program mount. The worker image still has built-in fallback programs.
TEST_AGENT_PROGRAM_ROOT=/data/testagent/programs

# Frontend dist build. Use the enterprise API base URL; do not append /api because the client adds it.
VITE_TEST_AGENT_API_BASE_URL=http://122.233.30.2

# Java model provider. Values mirror openclaw enterprise icbc-openai defaults.
TEST_AGENT_MODEL_CATALOG_SOURCE=internal
TEST_AGENT_INTERNAL_DEFAULT_MODEL=Qwen3.6-35B-A3B
TEST_AGENT_ICBC_OPENAI_BASE_URL=http://ai-code.sdc.icbc:9070/icbc/jdt/model/api/openai/v1
TEST_AGENT_ICBC_OPENAI_TOKEN_ENV=ICBC_OPENAI_AUTH_TOKEN
ICBC_OPENAI_AUTH_TOKEN=eyJzdWIiOiJzbWFydHRlc3Q6dGVzdC1jYXNlLWdlbmVyYXRpb24ifQ.1qbws
TEST_AGENT_ICBC_OPENAI_AUTH_MODE=bearer
TEST_AGENT_ICBC_OPENAI_UCID_HEADER_NAME=ucid

# opencode worker image build.
TEST_AGENT_OPENCODE_WORKER_IMAGE=test-agent-opencode-worker:internal
OPENCODE_VERSION=1.17.8
OPENCODE_SOURCE_COMMIT=11e47f91496005aab4d7c5a2d0a7da5d2651b4ac
OPENCODE_SOURCE_REPOSITORY=https://github.com/anomalyco/opencode.git
GO_IMAGE=golang@sha256:167053a2bb901972bf2c1611f8f52c44d5fe7e762e5cab213708d82c421614db
BUN_IMAGE=oven/bun@sha256:9dba1a1b43ce28c9d7931bfc4eb00feb63b0114720a0277a8f939ae4dfc9db6f
NODE_IMAGE=node@sha256:e24976116684e0fd211cbdb3c40fc9cb997565d063fb7fe656d2e2b603c5bb0a

# Worker port ranges must be the host-published ports Java will use in opencode baseUrl.
OPENCODE_WORKER_BACKEND_PORT=8080
OPENCODE_WORKER_PORT_START=4096
OPENCODE_WORKER_PORT_END=4105

# Build mirrors.
NPM_REGISTRY=https://registry.npmmirror.com
COREPACK_NPM_REGISTRY=https://registry.npmmirror.com
GOPROXY=https://goproxy.cn,direct
DEBIAN_MIRROR=https://mirrors.tuna.tsinghua.edu.cn/debian
DEBIAN_SECURITY_MIRROR=https://mirrors.tuna.tsinghua.edu.cn/debian-security

# Backend jar, frontend dist, external programs and image tarballs are written here by deploy/internal/package-release.sh.
TEST_AGENT_IMAGE_OUTPUT_DIR=/data/testagent/dist
