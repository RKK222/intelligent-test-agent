{
  "name": "test-agent-frontend",
  "private": true,
  "packageManager": "pnpm@10.25.0",
  "scripts": {
    "dev": "corepack pnpm --filter @test-agent/agent-web dev",
    "build": "corepack pnpm --filter @test-agent/agent-web build",
    "lint": "corepack pnpm -r lint",
    "typecheck": "corepack pnpm -r typecheck",
    "test": "vitest run",
    "e2e": "playwright test",
    "e2e:real": "TEST_AGENT_RUN_REAL_E2E=1 playwright test --config=playwright.real.config.ts"
  },
  "devDependencies": {
    "@playwright/test": "1.61.0",
    "@tailwindcss/vite": "4.3.1",
    "@tanstack/vue-virtual": "3.13.13",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/vue": "8.1.0",
    "@vitejs/plugin-vue": "6.0.7",
    "@vue/test-utils": "2.4.11",
    "jsdom": "29.1.1",
    "typescript": "6.0.3",
    "vite": "8.0.16",
    "vitest": "4.1.9",
    "vue": "3.5.38",
    "vue-tsc": "3.3.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "vue-demi"
    ]
  }
}
