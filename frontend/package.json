{
  "name": "test-agent-frontend",
  "private": true,
  "packageManager": "pnpm@10.25.0",
  "scripts": {
    "dev": "corepack pnpm --filter @test-agent/agent-web dev",
    "build": "corepack pnpm --filter @test-agent/agent-web build",
    "lint": "corepack pnpm -r lint",
    "typecheck": "corepack pnpm -r typecheck",
    "test": "vitest run",
    "e2e": "playwright test"
  },
  "devDependencies": {
    "@playwright/test": "1.61.0",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@vitejs/plugin-react": "6.0.2",
    "jsdom": "29.1.1",
    "typescript": "6.0.3",
    "vitest": "4.1.9"
  }
}
